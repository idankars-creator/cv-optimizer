## Required (server-only)
# Anthropic API key used by server routes (never expose to client)
ANTHROPIC_API_KEY=

## Clerk auth
# Publishable key (client-safe) and secret key (server-only) from the Clerk dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Point Clerk at the app-hosted (embedded) auth pages instead of Clerk's hosted
# origin. These mirror the signInUrl/signUpUrl props set on <ClerkProvider> in
# app/layout.tsx — keeping auth same-origin so persisted client state survives.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

## Supabase (client-safe)
# Your Supabase project URL (safe to expose to client)
NEXT_PUBLIC_SUPABASE_URL=
# Your Supabase anon/public key (safe to expose to client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

## Supabase (server-only)
# Service role key (full access) - server only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=

## Polar.sh (server-only)
# Organization access token from https://polar.sh/dashboard/<org>/settings (Developers section)
POLAR_ACCESS_TOKEN=
# Webhook signing secret from https://polar.sh/dashboard/<org>/settings/webhooks
POLAR_WEBHOOK_SECRET=
# "production" or "sandbox"
POLAR_SERVER=production

## Polar product IDs (server-only)
POLAR_PRODUCT_STARTER=
POLAR_PRODUCT_PRO=
# 80%-off Pro engagement flash (5-min, fires after a few builder actions).
# Create a dedicated discounted Polar product (~$1.80) — the offer self-hides until set.
POLAR_PRODUCT_PRO_FLASH=
POLAR_PRODUCT_ULTIMATE=

## App URL used for post-checkout redirect (e.g. https://hired-cv.vercel.app)
NEXT_PUBLIC_APP_URL=

## PostHog (client-safe; reverse-proxied via /ingest, see next.config.js)
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com
