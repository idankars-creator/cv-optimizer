## Required (server-only)
# Anthropic API key used by server routes (never expose to client)
ANTHROPIC_API_KEY=

## Supabase (client-safe)
# Your Supabase project URL (safe to expose to client)
NEXT_PUBLIC_SUPABASE_URL=
# Your Supabase anon/public key (safe to expose to client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

## Supabase (server-only)
# Service role key (full access) - server only, NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=

## Polar.sh (server-only)
# Organization access token from https://polar.sh/dashboard/<org>/settings (Developers section)
POLAR_ACCESS_TOKEN=
# Webhook signing secret from https://polar.sh/dashboard/<org>/settings/webhooks
POLAR_WEBHOOK_SECRET=
# "production" or "sandbox"
POLAR_SERVER=production

## Polar product IDs (server-only)
POLAR_PRODUCT_STARTER=
POLAR_PRODUCT_PRO=
POLAR_PRODUCT_ULTIMATE=

## App URL used for post-checkout redirect (e.g. https://hired-cv.vercel.app)
NEXT_PUBLIC_APP_URL=
