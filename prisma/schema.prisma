// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @unique // Matches Clerk User ID (user_2N...)
  email     String   @unique
  credits   Int      @default(2) // New users get 2 free credits (lets them see the optimized result + retry once before paywall)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resumes          Resume[]
  feedbacks        Feedback[]
  purchases        Purchase[]
  couponRedemptions CouponRedemption[]
  optimizations    OptimizationLog[]

  @@index([createdAt])
}

model OptimizationLog {
  id          String   @id @default(cuid())
  userId      String
  userEmail   String
  jobTitle    String?
  companyName String?
  matchScore  Int?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Resume {
  id         String   @id @default(cuid())
  title      String   // e.g. "Software Engineer CV"
  data       Json     // Stores the full resume object structure
  template   String   // e.g. "modern-sidebar"
  themeColor String?  // e.g. "#10b981"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id])
}

model Feedback {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  source    String?
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Purchase {
  id           String   @id @default(cuid())
  userId       String
  amount       Float
  plan         String
  polarOrderId String?  @unique
  status       String   @default("completed")
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

model Coupon {
  id        String   @id @default(cuid())
  code      String   @unique
  credits   Int      // How many credits it gives
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  
  redemptions CouponRedemption[]
}

model CouponRedemption {
  id         String   @id @default(cuid())
  userId     String
  couponId   String
  redeemedAt DateTime @default(now())
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  
  @@unique([userId, couponId]) // Ensures one redemption per user per coupon
  @@index([userId])
  @@index([couponId])
}
