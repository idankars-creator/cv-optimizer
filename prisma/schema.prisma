// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @unique // Matches Clerk User ID (user_2N...)
  email     String   @unique
  credits   Int      @default(2) // New users get 2 free credits (lets them see the optimized result + retry once before paywall)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Gamification + onboarding columns introduced in the career-hub redesign.
  // `targetRoles` is set from the marketing role-picker; everything else is
  // updated server-side via lib/gamification.ts.
  xp           Int       @default(0)
  streakDays   Int       @default(0)
  lastActiveAt DateTime?
  targetRoles  String[]  @default([])

  resumes          Resume[]
  feedbacks        Feedback[]
  purchases        Purchase[]
  couponRedemptions CouponRedemption[]
  optimizations    OptimizationLog[]
  analyses         Analysis[]
  generatedResumes GeneratedResume[]
  voiceSessions    VoiceSession[]
  chatSessions     ChatSession[]

  @@index([createdAt])
}

// A saved chat-builder conversation. Unlike the voice session (metadata only),
// we DO persist the transcript here so signed-in users get cross-device history
// and can resume any past chat. `resume` is the ResumeData snapshot at last save
// (powers the history-list preview + instant resume without replaying tools).
model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  title     String        @default("New chat")
  resume    Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ChatMessage[]

  @@index([userId, updatedAt])
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  role      String      // "user" | "assistant"
  content   String      @db.Text
  display   String?     @db.Text
  tools     Json?       // ChatToolEvent[] (sparkle chips)
  position  Int         // preserves order within the session
  createdAt DateTime    @default(now())

  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, position])
}

// Persisted optimization run. Replaces the sessionStorage-only flow so users
// can revisit analyses, unlock improvements asynchronously, and we can rank
// improvements by score impact for the blurred-paywall UI.
model Analysis {
  id             String        @id @default(cuid())
  userId         String
  cvText         String        @db.Text
  jobTitle       String?
  overallScore   Int?
  optimizedScore Int?
  raw            Json
  createdAt      DateTime      @default(now())

  improvements Improvement[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// One row per improvement returned by the analyze endpoint. `scoreImpact`
// drives the per-item "+X pts" chips; `unlocked=false` rows render through
// <BlurredLock>. A successful credit spend flips every row of an analysis
// to unlocked=true (single mental model — unlock-all-per-analysis).
model Improvement {
  id          String   @id @default(cuid())
  analysisId  String
  text        String   @db.Text
  scoreImpact Int
  category    String
  unlocked    Boolean  @default(false)
  position    Int

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([analysisId])
}

// One row per role in the multi-role generation. content is the ResumeData
// JSON ready to feed back into the existing builder/templates. First card
// (lowest createdAt for a given run) is unlocked=true; the rest are blurred
// until a credit spend flips a single row.
model GeneratedResume {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   Json
  score     Int?
  unlocked  Boolean  @default(false)
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, role])
}

// Metadata-only record of a voice CV builder session. We deliberately do NOT
// store the transcript — it lives in sessionStorage during the call and is
// discarded server-side after Claude returns the finalized ResumeData.
model VoiceSession {
  id          String   @id @default(cuid())
  userId      String
  durationSec Int
  turns       Int
  finalized   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OptimizationLog {
  id          String   @id @default(cuid())
  userId      String
  userEmail   String
  jobTitle    String?
  companyName String?
  matchScore  Int?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Resume {
  id         String   @id @default(cuid())
  title      String   // e.g. "Software Engineer CV"
  data       Json     // Stores the full resume object structure
  template   String   // e.g. "modern-sidebar"
  themeColor String?  // e.g. "#10b981"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId     String
  user       User     @relation(fields: [userId], references: [id])
}

model Feedback {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  source    String?
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Purchase {
  id           String   @id @default(cuid())
  userId       String
  amount       Float
  plan         String
  polarOrderId String?  @unique
  status       String   @default("completed")
  // Google Ads click ID captured on landing and threaded through Polar
  // checkout metadata. Required for the Purchase conversion to verify in
  // Google Ads — without it the tag fires but Google can't match the
  // conversion back to a click and flags the goal "Misconfigured".
  gclid        String?
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([gclid])
}

model Coupon {
  id        String   @id @default(cuid())
  code      String   @unique
  credits   Int      // How many credits it gives
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  
  redemptions CouponRedemption[]
}

model CouponRedemption {
  id         String   @id @default(cuid())
  userId     String
  couponId   String
  redeemedAt DateTime @default(now())
  
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  
  @@unique([userId, couponId]) // Ensures one redemption per user per coupon
  @@index([userId])
  @@index([couponId])
}
